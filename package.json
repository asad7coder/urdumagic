{
  "name": "urdumagic",
  "version": "0.3.0",
  "description": "Lightweight TypeScript library for English, Urdu, and Roman Urdu on the web",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./react": "./dist/react/index.js",
    "./server": "./dist/server/index.js",
    "./next": {
      "import": "./dist/next/index.js",
      "require": "./dist/next/plugin.js"
    },
    "./react-server": "./dist/server/react-server.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vite build && vite build --config vite.iife.config.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "prepublishOnly": "npm run test:run && npm run build",
    "demo": "npm run build && npx --yes http-server ./demo -p 3000"
  },
  "keywords": [
    "urdu",
    "roman-urdu",
    "transliteration",
    "translation",
    "pakistan",
    "rtl",
    "i18n"
  ],
  "author": "Muhammad Asad",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/muhammadasad/urdumagic.git"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rollup-plugin-copy": "^3.5.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-dts": "^4.4.0",
    "vite-plugin-static-copy": "^4.1.0",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "react": ">=16",
    "react-dom": ">=16"
  },
  "dependencies": {
    "node-html-parser": "^7.1.0"
  }
}
